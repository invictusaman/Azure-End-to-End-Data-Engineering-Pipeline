{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "dfend2end"
		},
		"azure_dakelake_con_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'azure_dakelake_con'"
		},
		"azure_end2end_con_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'azure_end2end_con'"
		},
		"azure_dakelake_con_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://storageend2end.dfs.core.windows.net/"
		},
		"azure_end2end_con_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "end2end-server.database.windows.net"
		},
		"azure_end2end_con_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "azureprojectDB"
		},
		"azure_end2end_con_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "invictusaman"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "dfend2end_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"azure_dakelake_con_accountKey": {
						"value": "[parameters('azure_dakelake_con_accountKey')]"
					},
					"azure_end2end_con_password": {
						"value": "[parameters('azure_end2end_con_password')]"
					},
					"azure_dakelake_con_properties_typeProperties_url": {
						"value": "[parameters('azure_dakelake_con_properties_typeProperties_url')]"
					},
					"azure_end2end_con_properties_typeProperties_server": {
						"value": "[parameters('azure_end2end_con_properties_typeProperties_server')]"
					},
					"azure_end2end_con_properties_typeProperties_database": {
						"value": "[parameters('azure_end2end_con_properties_typeProperties_database')]"
					},
					"azure_end2end_con_properties_typeProperties_userName": {
						"value": "[parameters('azure_end2end_con_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}